# 项目配置
PROJECT_NAME="local-knowledge-base"
ENVIRONMENT="development"
LOG_LEVEL="INFO"

# 数据路径
DATA_DIR="./data"
RAW_DOCS_DIR="${DATA_DIR}/raw_docs"
PROCESSED_DIR="${DATA_DIR}/processed"
VECTOR_STORE_DIR="${DATA_DIR}/vector_store"

# 本地模型配置
LOCAL_MODEL_PROVIDER="ollama"  # ollama, vllm, transformers
LOCAL_MODEL_NAME="deepseek-v2-lite:16b-q4_K_M"
LOCAL_EMBEDDING_MODEL="BAAI/bge-m3"
LOCAL_EMBEDDING_DEVICE="cpu"  # cpu or cuda

# API配置（可选，用于后备）
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
KIMI_API_KEY=""
KIMI_MODEL="moonshot-v1-8k-vision-preview"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-haiku-20240307"

# 向量数据库配置
VECTOR_DB_TYPE="chroma"  # chroma, qdrant, faiss
CHROMA_PERSIST_DIR="${VECTOR_STORE_DIR}/chroma"
CHROMA_COLLECTION_NAME="knowledge_base"

# 文本处理配置
CHUNK_SIZE=800
CHUNK_OVERLAP=100
MAX_CHUNKS_PER_DOC=100

# RAG配置
RETRIEVAL_TOP_K=4
RETRIEVAL_SCORE_THRESHOLD=0.7
ENABLE_RERANKING=false
RERANKER_MODEL="BAAI/bge-reranker-large"

# Agent配置
ENABLE_AGENTS=true
AGENT_MAX_ITERATIONS=5
AGENT_TOOLS=["retrieval", "calculator", "web_search"]

# 服务器配置
API_HOST="0.0.0.0"
API_PORT=8000
STREAMLIT_PORT=8501
CORS_ALLOW_ORIGINS=http://localhost:8501,http://localhost:3000

# 模型缓存路径配置
MODEL_CACHE_PATH=~/.cache/models

# 硬件配置
CUDA_VISIBLE_DEVICES="0"
MAX_GPU_MEMORY="10GB"
CPU_WORKER_THREADS=6